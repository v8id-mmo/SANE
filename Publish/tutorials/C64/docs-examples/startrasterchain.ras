program StartRasterChainDemo;
var
	frame : byte = 0;

interrupt Raster();
begin
	StartIRQ(0);
	inc(frame);
	screen_bg_col := frame;
	CloseIRQ();
end;

begin
	disableciainterrupts();
	// one call instead of RasterIRQ() + EnableRasterIRQ() + enableirq()
	StartRasterChain(Raster(), 100, 0);
	loop();
end.
