program ReturnInterruptDemo;
var
	frame : byte = 0;

interrupt Raster();
begin
	startirq(0);
	inc(frame);

	if (frame > 20) then begin
		screen_bg_col := black;
		closeirq();
		returninterrupt(); // bail out immediately, skip the rest of the handler
	end;

	screen_bg_col := frame;
	closeirq();
end;

begin
	disableciainterrupts();
	startrasterchain(Raster(), 100, 0);
	loop();
end.
