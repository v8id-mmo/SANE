program IncBinDemo;
var
	rawData : incbin("sample_data.bin");
	i : byte;
	total : integer;
begin
	clearscreen(key_space,screen_char_loc);

	total := 0;
	for i:=0 to 7 do
		total := total + rawData[i];

	moveto(0,0,hi(screen_char_loc));
	printstring("sum:",0,40);
	moveto(5,0,hi(screen_char_loc));
	printdecimal(total,3);

	loop();
end.
