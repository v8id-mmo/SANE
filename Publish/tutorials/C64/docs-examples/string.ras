program StringDemo;
var
	greeting : string = "HELLO WORLD";
	names : array[3] of string = ("ALICE","BOB","CARL");
	i : byte;
begin
	clearscreen(key_space,screen_char_loc);

	printstring(greeting,0,0);

	for i:=0 to 2 do
	begin
		moveto(0,i+1,hi(screen_char_loc));
		printstring(names[i],0,40);
	end;

	loop();
end.
